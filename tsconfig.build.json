{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "importHelpers": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "noEmitOnError": true,
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "*.d.ts"],
  "exclude": ["**/*.spec.ts", "dist", "node_modules"]
}
