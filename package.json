{
  "name": "@codeperfect/eslint-plugin",
  "version": "1.0.0",
  "description": "Custom ESLint rules for TypeScript repositories",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "custom-rules",
    "typescript",
    "linting"
  ],
  "homepage": "https://github.com/codeperfect/eslint-plugin#readme",
  "bugs": {
    "url": "https://github.com/codeperfect/eslint-plugin/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codeperfect/eslint-plugin.git"
  },
  "license": "MIT",
  "author": "CodePerfect",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "\n# --------------- SCM --------------- #": "",
    "commit": "npx --yes git-cz",
    "prepare": "husky",
    "\n# --------------- BUILDING --------------- #": "",
    "build": "npm run clean && npm run compile",
    "clean": "npx --yes rimraf dist",
    "compile": "tsc -b -f ./tsconfig.build.json",
    "pack": "npm pack --pack-destination dist",
    "\n# --------------- LINTING --------------- #": "",
    "\t• --------------- checking --------------- •": "",
    "eslint": "npx --yes eslint --max-warnings=0",
    "lint": "npm run lint:run",
    "lint:run": "npm run prettier && npm run eslint",
    "lint:staged": "npx --yes tsx scripts/lint-staged.ts",
    "prettier": "npx --yes prettier --ignore-unknown --check .",
    "\n\t• --------------- fixing --------------- •": "",
    "eslint:fix": "npm run check:rules && npm run eslint -- --fix",
    "lint:fix": "npm run prettier:write && npm run eslint:fix",
    "prettier:write": "npm run prettier -- --write",
    "\n\t• --------------- helpers --------------- •": "",
    "check:rules": "npx --yes eslint-config-prettier eslint.config.ts",
    "benchmark:rules": "npx --yes tsx src/benchmark-rules.ts",
    "eslint:inspect": "npx --yes @eslint/config-inspector",
    "\n# --------------- TESTING --------------- #": "",
    "typecheck": "tsc --noEmit",
    "typecheck:spec": "tsc -p tsconfig.spec.json --noEmit",
    "validate": "npm run lint && npm run typecheck && npm run typecheck:spec && npm run test && npm run build && npm run pack",
    "\n\t• --------------- unit --------------- •": "",
    "tdd": "npx --yes vitest run --watch --silent=true --coverage.enabled=false",
    "tdd:notify": "npm run tdd -- --notify",
    "test": "npx --yes vitest run"
  },
  "dependencies": {
    "minimatch": "^9.0.5"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  },
  "devDependencies": {
    "@codeperfect/eslint-config": "file:../eslint-config/dist/codeperfect-eslint-config-1.0.0.tgz",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@commitlint/cz-commitlint": "^20.4.1",
    "@eslint/js": "^9.39.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.2.1",
    "@typescript-eslint/rule-tester": "^8.46.2",
    "@vitest/coverage-v8": "^4.0.18",
    "chalk": "^5.6.2",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "eslint": "^9.39.2",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "lodash-es": "^4.17.23",
    "memfs": "^4.56.11",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
