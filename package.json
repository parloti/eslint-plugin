{
  "name": "@codeperfect/eslint-plugin",
  "version": "1.0.0",
  "description": "Custom ESLint rules for TypeScript repositories",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "custom-rules",
    "typescript",
    "linting"
  ],
  "homepage": "https://github.com/parloti/eslint-plugin#readme",
  "bugs": {
    "url": "https://github.com/parloti/eslint-plugin/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/parloti/eslint-plugin.git"
  },
  "license": "MIT",
  "author": "CodePerfect",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "\n# --------------- SCM --------------- #": "",
    "commit": "npx --yes git-cz",
    "prepare": "husky",
    "\n# --------------- BUILDING --------------- #": "",
    "build": "npm run clean && npm run compile",
    "clean": "npx --yes rimraf dist",
    "compile": "tsc -b -f ./tsconfig.build.json",
    "docs": "npm run docs:api",
    "docs:api": "typedoc --options typedoc.json",
    "pack": "npm pack --pack-destination dist",
    "release:dry-run": "semantic-release --dry-run",
    "\n# --------------- LINTING --------------- #": "",
    "\t• --------------- checking --------------- •": "",
    "eslint": "npx --yes eslint --max-warnings=0",
    "lint": "npm run lint:run",
    "lint:run": "npm run prettier && npm run eslint",
    "lint:staged": "npx --yes tsx scripts/lint-staged.ts",
    "prettier": "npx --yes prettier --ignore-unknown --check .",
    "\n\t• --------------- fixing --------------- •": "",
    "eslint:fix": "npm run check:rules && npm run eslint -- --fix",
    "lint:fix": "npm run prettier:write && npm run eslint:fix",
    "prettier:write": "npm run prettier -- --write",
    "\n\t• --------------- helpers --------------- •": "",
    "check:rules": "npx --yes eslint-config-prettier eslint.config.ts",
    "benchmark:rules": "npx --yes tsx src/benchmark-rules.ts",
    "eslint:inspect": "npx --yes @eslint/config-inspector",
    "\n# --------------- TESTING --------------- #": "",
    "typecheck": "tsc --noEmit",
    "typecheck:spec": "tsc -p tsconfig.spec.json --noEmit",
    "validate": "npm run lint && npm run typecheck && npm run typecheck:spec && npm run test && npm run build && npm run pack",
    "\n\t• --------------- unit --------------- •": "",
    "tdd": "npx --yes vitest run --watch --silent=true --coverage.enabled=false",
    "tdd:notify": "npm run tdd -- --notify",
    "test": "npx --yes vitest run"
  },
  "dependencies": {
    "@codeperfect/eslint-config": "file:../eslint-config/dist/codeperfect-eslint-config-1.0.0.tgz",
    "@typescript-eslint/utils": "^8.57.2",
    "minimatch": "^10.2.4"
  },
  "peerDependencies": {
    "eslint": ">=10.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/cz-commitlint": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.5.0",
    "@typescript-eslint/rule-tester": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.2",
    "chalk": "^5.6.2",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "lodash-es": "^4.17.23",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2",
    "jiti": "^2.6.1",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitest/eslint-plugin": "^1.6.13",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.1",
    "eslint-plugin-jasmine": "^4.2.2",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-jsdoc": "^62.8.1",
    "eslint-plugin-perfectionist": "^5.7.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-rxjs-x": "^1.0.1",
    "eslint-plugin-unicorn": "^64.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
